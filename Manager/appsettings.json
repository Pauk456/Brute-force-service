{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Manager": {
    "RequestTimeoutSeconds": 120,
    "RequestTimeoutCheckIntervalSeconds": 3,
    "WorkerBaseUrls": [
      "http://worker1:8080",
      "http://worker2:8080",
      "http://worker3:8080",
      "http://worker4:8080"
    ],
    "Alphabet": "abcdefghijklmnopqrstuvwxyz0123456789"
  }
}
