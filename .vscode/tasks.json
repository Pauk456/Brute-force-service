{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/CrackHash.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "docker:up",
            "command": "docker",
            "type": "process",
            "args": [
                "compose",
                "up",
                "-d",
                "--build"
            ],
            "problemMatcher": []
        },
        {
            "label": "docker:down",
            "command": "docker",
            "type": "process",
            "args": [
                "compose",
                "down",
                "--remove-orphans"
            ],
            "problemMatcher": []
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/CrackHash.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/CrackHash.sln"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}